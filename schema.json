{
  "request": {
    "properties": {
      "prompt": {
        "title": "Prompt",
        "type": "string"
      },
      "height": {
        "maximum": 2048,
        "minimum": 256,
        "title": "Height",
        "type": "integer"
      },
      "width": {
        "maximum": 2048,
        "minimum": 256,
        "title": "Width",
        "type": "integer"
      },
      "input_image": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Input Image"
      },
      "reference_images": {
        "anyOf": [
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Reference Images"
      }
    },
    "required": [
      "prompt",
      "height",
      "width"
    ],
    "title": "RequestPayload",
    "type": "object"
  },
  "response": {
    "properties": {
      "image": {
        "title": "Image",
        "type": "string"
      }
    },
    "required": [
      "image"
    ],
    "title": "ResponsePayload",
    "type": "object"
  }
